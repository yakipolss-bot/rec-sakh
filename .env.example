# === Database (Xata.io PostgreSQL) ===
DATABASE_URL="postgresql://WORKSPACE_ID:API_KEY@REGION.sql.xata.sh:5432/DATABASE_NAME:BRANCH_NAME?sslmode=require"
SHADOW_DATABASE_URL="postgresql://WORKSPACE_ID:API_KEY@REGION.sql.xata.sh:5432/DATABASE_NAME:shadow?sslmode=require"

# === Admin bootstrap (comma-separated emails that get superadmin role) ===
ADMIN_EMAILS="admin@example.com"

# === JWT ===
JWT_SECRET="generate-with: openssl rand -hex 64"
JWT_REFRESH_SECRET="generate-with: openssl rand -hex 64"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="30d"

# === API ===
PORT=4000
CORS_ORIGIN="https://rec-sakh.vercel.app,http://localhost:3000"

# === Redis (Railway add-on) ===
REDIS_URL="redis://default:password@redis.railway.internal:6379"

# === Typesense (Railway add-on) ===
TYPESENSE_URL="http://typesense.railway.internal:8108"
TYPESENSE_API_KEY="your-typesense-api-key"
TYPESENSE_COLLECTION_PREFIX="rec_sakh_"

# === Notifications ===
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@rec-sakh.ru"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="noreply@rec-sakh.ru"

SMS_API_KEY="your-sms-api-key"
SMS_API_URL="https://sms.ru/api/send"
SMS_FROM="Sakhcom"

TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@rec-sakh.ru"

# === External APIs ===
NEWS_API_KEY="generate-with: openssl rand -hex 32"
OPENWEATHERMAP_API_KEY="your-openweathermap-api-key"

# === Payments (mock) ===
YUKASSA_SHOP_ID="your-yookassa-shop-id"
YUKASSA_SECRET_KEY="your-yookassa-secret-key"
SBP_MERCHANT_ID="your-sbp-merchant-id"
CRYPTO_WALLET="your-crypto-wallet-address"

# === Supabase ===
SUPABASE_URL="https://fhdtteyrcczqlmvwjhps.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# === Frontend ===
VITE_API_URL="https://your-api.railway.app/api/v1"
