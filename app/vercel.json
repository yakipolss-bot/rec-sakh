{
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/ssr" }
  ],
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "dist/**"
    }
  },
  "buildCommand": "NODE_ENV=production npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/client",
  "framework": null
}
